# ─── Auditor (attester) env — auditor's server ─────────────────────────
# Copy to .env.audit next to deploy/docker-compose.audit.yml:
#   cp audit-stack.env.attester.example .env.audit
#
# The auditor runs `setup --role attester`, which fills in
# ATTESTER_SECRET_KEY and generates ./attester.key. This file should NOT
# contain STELLAR_SECRET_KEY — that lives on the operator's server.
#
# Run every compose command with `--env-file .env.audit` and `--profile attester`:
#   docker compose --env-file .env.audit run --rm setup -- --role attester
#   docker compose --env-file .env.audit --profile attester up -d

# ── Image ───────────────────────────────────────────────────────────────
AUDIT_IMAGE=ghcr.io/ronnakamoto/nosqlbuddy-audit
AUDIT_IMAGE_TAG=latest

# ── MongoDB (auditor's independent replica member) ─────────────────────
ATTESTER_MONGO_URI=mongodb://host.docker.internal:27019

# ── Stellar network ──────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443

# Soroban contract ID (deployed by the operator — ask them for this).
CONTRACT_ID=

# ── Attester's Stellar key (written by setup; keep secret) ─────────────
ATTESTER_SECRET_KEY=

# ── Attester ed25519 oplog signing key ──────────────────────────────────
# Path on the host (generated by setup --role attester).
ATTESTER_KEY_FILE=./attester.key

# ── Tuning ───────────────────────────────────────────────────────────────
ATTESTER_PORT=9174
READER_PORT=9175
