# ─── Operator (publisher) env — company server ──────────────────────────
# Copy to .env.audit next to deploy/docker-compose.audit.yml:
#   cp audit-stack.env.publisher.example .env.audit
#
# The operator runs `setup --role publisher`, which fills in
# STELLAR_SECRET_KEY and CONTRACT_ID. This file should NOT contain
# ATTESTER_SECRET_KEY — that lives on the auditor's server.
#
# Run every compose command with `--env-file .env.audit` and `--profile publisher`:
#   docker compose --env-file .env.audit run --rm setup -- --role publisher
#   docker compose --env-file .env.audit --profile publisher up -d

# ── Image ───────────────────────────────────────────────────────────────
AUDIT_IMAGE=ghcr.io/ronnakamoto/nosqlbuddy-audit
AUDIT_IMAGE_TAG=latest

# ── MongoDB (operator's replica set) ────────────────────────────────────
PUBLISHER_MONGO_URI=mongodb://host.docker.internal:27017/?replicaSet=rs0

# ── Stellar network ──────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443

# Soroban contract (written by setup --role publisher).
CONTRACT_ID=

# ── Publisher's Stellar key (written by setup; keep secret) ─────────────
STELLAR_SECRET_KEY=

# ── IPFS (batch publishing) ──────────────────────────────────────────────
IPFS_API_URL=http://host.docker.internal:5001
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# ── Tuning ───────────────────────────────────────────────────────────────
EPOCH_THRESHOLD=100
PUBLISHER_PORT=9173
READER_PORT=9175
