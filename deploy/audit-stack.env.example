# ─── NoSQLBuddy audit service — server deployment env ────────────────────
# Copy this to .env.audit next to deploy/docker-compose.audit.yml:
#   cp audit-stack.env.example .env.audit
# Then run every compose command with `--env-file .env.audit`, e.g.
#   docker compose --env-file .env.audit run --rm setup   # generate keys
#   docker compose --env-file .env.audit up -d            # start the stack
#
# The `setup` wizard fills in STELLAR_SECRET_KEY, ATTESTER_SECRET_KEY and
# CONTRACT_ID for you and writes ./attester.key. You still set the MongoDB
# URIs and (optionally) the image tag and IPFS endpoint below.

# ── Image ───────────────────────────────────────────────────────────────
# Published audit image. Pin AUDIT_IMAGE_TAG to a release (e.g. v0.1.0) in
# production; `latest` tracks the newest published build.
AUDIT_IMAGE=ghcr.io/ronnakamoto/nosqlbuddy-audit
AUDIT_IMAGE_TAG=latest

# ── MongoDB (YOUR replica set — this stack does not run a database) ───────
# Publisher connects to the primary; attester/reader connect to an
# INDEPENDENT replica member you control. If MongoDB runs on the same host,
# use host.docker.internal. For Atlas/remote, use your full SRV/standard URI.
PUBLISHER_MONGO_URI=mongodb://host.docker.internal:27017/?replicaSet=rs0
ATTESTER_MONGO_URI=mongodb://host.docker.internal:27019

# ── Stellar network ──────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443

# Soroban contract the roots are committed to. The setup wizard writes this.
# For mainnet, set your deployed contract ID (C...). Do NOT leave it blank.
CONTRACT_ID=

# ── Stellar keys (written by the setup wizard; keep secret) ──────────────
# Publisher's Stellar secret key (S..., signs commit transactions).
STELLAR_SECRET_KEY=
# Attester's Stellar secret key (S..., signs attest_oplog transactions).
# Must be a DIFFERENT key, controlled by the independent auditor.
ATTESTER_SECRET_KEY=

# Path to the attester's ed25519 oplog signing key on the host (written by
# the setup wizard). Mounted read-only into the attester container.
ATTESTER_KEY_FILE=./attester.key

# ── IPFS (batch publishing) ──────────────────────────────────────────────
# Local Kubo daemon on the host, or set Pinata credentials below instead.
IPFS_API_URL=http://host.docker.internal:5001
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# ── Tuning (optional) ────────────────────────────────────────────────────
EPOCH_THRESHOLD=100
# Host ports to publish the daemon HTTP APIs on.
PUBLISHER_PORT=9173
ATTESTER_PORT=9174
READER_PORT=9175
