# ─── Audit stack environment (Dev Mode) ─────────────────────────────────
# Copy this file to .env.audit and fill in your values:
#   cp audit-stack.env.example .env.audit
#
# These credentials are used by the publisher/attester containers in
# docker-compose.audit.yml. The daemon signs Stellar transactions natively
# (ed25519 + Soroban RPC) — no `stellar` CLI or identity mount is needed.

# The Stellar secret key (S... strkey, 56 chars) for the publisher.
# Generate one with `stellar keys generate --global <name> --network testnet`
# then export it: `stellar keys show <name> --secret-key` (or read it from
# ~/.config/stellar/identity/<name>.toml).
STELLAR_SECRET_KEY=

# The Stellar secret key (S... strkey) for the attester's account.
# This is separate from the ed25519 attester signing key (which is generated
# automatically inside the container). The attester uses this Stellar account
# to submit `attest_oplog` transactions.
ATTESTER_SECRET_KEY=

# Optional: override the bundled testnet contract ID. Use this after deploying
# a new contract via `nosqlbuddy-audit setup` so the daemon points to it.
CONTRACT_ID=

# Pinata IPFS credentials (for publishing audit batches).
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# ─── MongoDB endpoints the audit stack watches ──────────────────────────
# In the real world, writes happen to the DBA/operator-maintained database,
# and the publisher captures them over a change stream. Point these at your
# own replica set / cluster to audit it. Change streams require a replica set
# or sharded cluster (a standalone mongod won't work).
#
# If MongoDB runs on the host, reach it with host.docker.internal, e.g.
#   PUBLISHER_MONGO_URI=mongodb://host.docker.internal:27017/?replicaSet=rs0
#
# Leave these unset to use the bundled demo 3-node replica set
# (docker-compose.audit-db.yml): publisher watches mongo1/2/3, and the
# attester/reader use the independent member mongo3 as the trust anchor.
#
# The publisher builds the audit log from this endpoint's change stream.
PUBLISHER_MONGO_URI=
# The attester independently recomputes the oplog hash from this endpoint.
# For a real trust anchor this should be an independent replica member the
# operator does not control.
ATTESTER_MONGO_URI=
# The reader verifies on-chain roots against a local copy read from here.
READER_MONGO_URI=
