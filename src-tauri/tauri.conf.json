{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NoSQLBuddy",
  "version": "0.1.0",
  "identifier": "studio.nosqlbuddy.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NoSQLBuddy",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "dmg",
      "msi",
      "nsis",
      "appimage",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Cross-platform MongoDB management studio",
    "longDescription": "NoSQLBuddy is a professional, native MongoDB management studio with a visual query builder, aggregation pipeline editor, SQL-to-Mongo translation, schema and index tooling, and safe migration diffs.",
    "category": "DeveloperTool",
    "publisher": "NoSQLBuddy",
    "copyright": "(c) 2026 NoSQLBuddy",
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "resources": {
      "resources/circuits/merkle_inclusion.r1cs": "resources/circuits/merkle_inclusion.r1cs",
      "resources/circuits/merkle_inclusion.wasm": "resources/circuits/merkle_inclusion.wasm",
      "resources/circuits/merkle_inclusion.pkey": "resources/circuits/merkle_inclusion.pkey",
      "resources/circuits/merkle_inclusion.vkey": "resources/circuits/merkle_inclusion.vkey",
      "resources/circuits/audited_action.r1cs": "resources/circuits/audited_action.r1cs",
      "resources/circuits/audited_action.wasm": "resources/circuits/audited_action.wasm",
      "resources/circuits/audited_action.pkey": "resources/circuits/audited_action.pkey",
      "resources/circuits/audited_action.vkey": "resources/circuits/audited_action.vkey",
      "resources/contract/zk_audit_commitment.wasm": "resources/contract/zk_audit_commitment.wasm",
      "../docker-compose.audit.yml": "stack/docker-compose.audit.yml",
      "../docker-compose.audit-db.yml": "stack/docker-compose.audit-db.yml",
      "../scripts/rs-init-audit.js": "stack/scripts/rs-init-audit.js",
      "../scripts/seed.js": "stack/scripts/seed.js",
      "../audit-stack.env.example": "stack/audit-stack.env.example"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/ronnakamoto/nosql-buddy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5QzhFQzJFN0IwM0Q0QUEKUldTcTFBTjdMdXpJK1NGL2tlRkNVN2o3QmxzZCtpdXh5c1lNQWRQZytWYW9xYXNKL0UwaHlHS3IK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
