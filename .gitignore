# Dependencies
node_modules/
.pnpm-store/
.yarn/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/
out/

# Rust
src-tauri/target/
# Cover all nested target dirs (zk-audit/target/, zk-audit/soroban-contract/target/, etc.)
zk-audit/**/target/
# Cargo.lock should be committed for binary applications, so do NOT ignore it.
# But ignore Cargo.lock for library/spike/throwaway crates that pin transitive deps.
zk-spike/**/Cargo.lock
zk-audit/**/Cargo.lock
# Soroban test snapshots (auto-generated by cargo test)
zk-audit/soroban-contract/test_snapshots/

# Tauri generated
src-tauri/gen/

# ZK spike — Circom / snarkjs / Soroban artifacts
# Cloned reference repo (not our code)
zk-spike/soroban-examples/
# Circom-compiled C++/JS witness generators (regenerated from .circom)
zk-spike/circuits/*_cpp/
zk-spike/circuits/*_js/
# snarkjs trusted-setup artifacts (regenerable, large)
zk-spike/circuits/build/
zk-spike/circuits/*.r1cs
zk-spike/circuits/*.sym
zk-spike/circuits/*_input.json
zk-spike/circuits/package-lock.json
# Rust spike crate build dirs
zk-spike/poseidon-check/target/
zk-spike/verifier-contract/target/
# Generated spike inputs/results
zk-spike/poseidon-check/merkle_input.json
zk-spike/poseidon-check/merkle_root.txt
zk-spike/rust-prover/rust_proof_args*.json
zk-spike/scripts/invoke_args.json
# Soroban test snapshots (auto-generated by cargo test)
zk-spike/verifier-contract/test_snapshots/

# OS
.DS_Store
Thumbs.db

# Audit stack local env (credentials — never commit)
.env.audit
# Generated attester Ed25519 signing key (created by nosqlbuddy-audit setup)
attester.key
# Generated Groth16 proving/verifying keys (regenerable from R1CS via zk-audit-ceremony)
src-tauri/resources/circuits/*.pkey
src-tauri/resources/circuits/*.vkey


# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Playwright
test-results/
playwright-report/
screenshots/

# Env
.env
.env.local
.env.*.local
.env.*

# MCP / local tool configs that may contain secrets
*.mcp.json

# Misc
*.tmp
*.temp

target/
docs/